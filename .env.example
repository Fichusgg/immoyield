# Supabase — required for auth and database
# Find these in your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-public-key>

# Supabase service role key — used by the cron job to bypass RLS
# ⚠ Keep this secret — never expose on the client side
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Cron job secret — used to authenticate requests to /api/cron/*
# Set the same value in Vercel Cron config (vercel.json already wired)
CRON_SECRET=<a-long-random-secret>
